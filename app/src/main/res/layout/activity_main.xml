<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    android:background="@color/bg">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/navHost"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/miniPlayer"
        android:layout_width="0dp"
        android:layout_height="76dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_miniplayer_glass"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivMiniCover"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:scaleType="centerCrop"
            android:translationY="-4dp"
            app:shapeAppearanceOverlay="@style/RoundedContinueCover"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvMiniTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:textColor="@color/textPrimary"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/ivMiniCover"
            app:layout_constraintTop_toTopOf="@id/ivMiniCover"
            app:layout_constraintEnd_toStartOf="@id/btnMiniPrev"/>

        <TextView
            android:id="@+id/tvMiniArtist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:textColor="@color/textSecondary"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/ivMiniCover"
            app:layout_constraintTop_toBottomOf="@id/tvMiniTitle"
            app:layout_constraintBottom_toBottomOf="@id/ivMiniCover"
            app:layout_constraintEnd_toStartOf="@id/btnMiniPrev"/>

        <ImageButton
            android:id="@+id/btnMiniPrev"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_prev"
            app:tint="@color/textPrimary"
            android:translationY="-3dp"
            app:layout_constraintEnd_toStartOf="@id/btnMiniPlay"
            app:layout_constraintTop_toTopOf="@id/ivMiniCover"
            app:layout_constraintBottom_toBottomOf="@id/ivMiniCover"/>

        <ImageButton
            android:id="@+id/btnMiniPlay"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_play"
            app:tint="@color/textPrimary"
            android:translationY="-3dp"
            app:layout_constraintEnd_toStartOf="@id/btnMiniNext"
            app:layout_constraintTop_toTopOf="@id/ivMiniCover"
            app:layout_constraintBottom_toBottomOf="@id/ivMiniCover"/>

        <ImageButton
            android:id="@+id/btnMiniNext"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_next"
            app:tint="@color/textPrimary"
            android:translationY="-3dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivMiniCover"
            app:layout_constraintBottom_toBottomOf="@id/ivMiniCover"/>

        <ProgressBar
            android:id="@+id/miniProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:max="1000"
            android:indeterminate="false"
            android:progressDrawable="@drawable/mini_player_progress"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/navIndicator"
            android:layout_width="34dp"
            android:layout_height="4dp"
            android:translationX="0dp"
            android:elevation="20dp"
            android:layout_gravity="bottom"
            android:layout_marginBottom="15dp"
            android:background="@drawable/bg_pill"/>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_bottom_nav"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="6dp"
            android:elevation="14dp"
            android:stateListAnimator="@null"
            android:outlineProvider="none"
            app:itemPaddingTop="8dp"
            app:itemPaddingBottom="1dp"
            android:clipChildren="false"
            app:menu="@menu/bottom_nav_menu"
            app:labelVisibilityMode="labeled"
            app:itemHorizontalTranslationEnabled="false"
            app:itemIconSize="30dp"
            app:itemIconTint="@color/bottom_nav_colors"
            app:itemTextColor="@color/bottom_nav_colors"
            app:itemRippleColor="@android:color/transparent"
            app:itemTextAppearanceActive="@style/BottomNavText"
            app:itemTextAppearanceInactive="@style/BottomNavText"/>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>