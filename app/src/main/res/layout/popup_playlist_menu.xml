<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/background_popup_menu"
    android:elevation="12dp"
    android:padding="10dp">

    <LinearLayout
        android:id="@+id/actionImport"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:background="@drawable/popup_item_selected">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/icon_add"
            android:tint="#F3F3F3"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Import"
            android:textSize="16sp"
            android:textColor="@color/textPrimary"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionEdit"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:background="@drawable/popup_item_selected">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/icon_edit"
            android:tint="#F3F3F3"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit playlist"
            android:textSize="16sp"
            android:textColor="@color/textPrimary"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionInfo"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:background="@drawable/popup_item_selected">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/icon_info"
            android:tint="#F3F3F3"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Playlist info"
            android:textSize="16sp"
            android:textColor="@color/textPrimary"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionDelete"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:background="@drawable/popup_item_selected">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/icon_delete"
            android:tint="@color/danger"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete playlist"
            android:textSize="16sp"
            android:textColor="@color/danger"
            android:layout_marginStart="10dp"/>
    </LinearLayout>
</LinearLayout>