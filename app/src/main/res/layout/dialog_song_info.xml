<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/background_dialog_card">

    <ImageView
        android:id="@+id/ivSongInfoCover"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_gravity="center"
        android:scaleType="centerCrop"
        android:layout_marginBottom="20dp"
        android:background="@drawable/background_cover_rounded"
        android:clipToOutline="true" />

    <TextView
        android:id="@+id/tvSongInfoTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:gravity="center"
        android:textAlignment="center"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Artist"
        android:textStyle="bold|italic"
        android:textSize="17sp"
        android:textColor="@color/textSecondary"/>

    <TextView
        android:id="@+id/tvSongInfoArtist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/textPrimary"
        android:textSize="15sp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Album"
        android:textStyle="bold|italic"
        android:textSize="17sp"
        android:textColor="@color/textSecondary"/>

    <TextView
        android:id="@+id/tvSongInfoAlbum"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/textPrimary"
        android:textSize="15sp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Produced by"
        android:textStyle="bold|italic"
        android:textSize="17sp"
        android:textColor="@color/textSecondary"/>

    <TextView
        android:id="@+id/tvSongInfoProducer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/textPrimary"
        android:textSize="15sp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Length"
        android:textStyle="bold|italic"
        android:textSize="17sp"
        android:textColor="@color/textSecondary"/>

    <TextView
        android:id="@+id/tvSongInfoLength"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/textPrimary"
        android:textSize="15sp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnCloseSongInfo"
        android:layout_width="120dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:text="Close"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:backgroundTint="@color/accent"/>
</LinearLayout>