<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_card">

    <ImageView
        android:id="@+id/ivSongInfoCover"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_gravity="center"
        android:scaleType="centerCrop"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_cover_rounded"
        android:clipToOutline="true" />

    <TextView
        android:id="@+id/tvSongInfoTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:gravity="center"
        android:textAlignment="center"
        android:layout_marginBottom="14dp" />

    <TextView
        android:id="@+id/tvSongInfoArtist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/textSecondary"
        android:textSize="17sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvSongInfoAlbum"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/textSecondary"
        android:textSize="17sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvSongInfoProducer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/textSecondary"
        android:textSize="17sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvSongInfoLength"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/textSecondary"
        android:textSize="17sp"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnCloseSongInfo"
        android:layout_width="140dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:text="Close"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:backgroundTint="@color/accent"/>
</LinearLayout>