<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:padding="8dp"
    android:background="@drawable/background_playlist_ripple">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivPlaylistCover"
        android:layout_width="0dp"
        android:layout_height="85dp"
        android:scaleType="centerCrop"
        android:src="@drawable/default_cover"
        app:shapeAppearanceOverlay="@style/RoundedPlaylistCover"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/ivOverlayIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/icon_liked"
        android:tint="@android:color/black"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/ivPlaylistCover"
        app:layout_constraintBottom_toBottomOf="@id/ivPlaylistCover"
        app:layout_constraintStart_toStartOf="@id/ivPlaylistCover"
        app:layout_constraintEnd_toEndOf="@id/ivPlaylistCover"/>

    <TextView
        android:id="@+id/tvPlaylistName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Favourite"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@color/textPrimary"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/ivPlaylistCover"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnMore"/>

    <TextView
        android:id="@+id/tvPlaylistCount"
        style="@style/SmallSecondary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1 song"
        android:textSize="12sp"
        android:layout_marginTop="1dp"
        app:layout_constraintTop_toBottomOf="@id/tvPlaylistName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ImageButton
        android:id="@+id/btnMore"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@android:color/transparent"
        android:src="@drawable/icon_more"
        android:scaleType="center"
        app:tint="@color/accent"
        app:layout_constraintTop_toTopOf="@id/tvPlaylistName"
        app:layout_constraintBottom_toBottomOf="@id/tvPlaylistCount"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>