<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvAppTitle"
            style="@style/WavvyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wavvy"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/tvHomeTitle"
            style="@style/SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:layout_marginTop="6dp"/>

        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good evening"
            android:textSize="20sp"
            android:textStyle="bold|italic"
            android:textColor="@color/textPrimary"
            android:layout_marginTop="6dp"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="120dp">

            <LinearLayout
                android:id="@+id/cardContinue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivContinueCover"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_launcher_foreground"
                    app:shapeAppearanceOverlay="@style/RoundedContinueCover"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="30dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Continue listening"
                        android:textSize="12sp"
                        android:textColor="@color/textSecondary"/>

                    <TextView
                        android:id="@+id/tvContinueTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Song title"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="@color/textPrimary"/>

                    <TextView
                        android:id="@+id/tvContinueArtist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Artist"
                        android:textSize="13sp"
                        android:textColor="@color/textSecondary"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="6dp"
                    android:src="@drawable/ic_play"
                    app:tint="@color/textPrimary"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tvRecentTitle"
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recently played"/>

            <TextView
                android:id="@+id/tvRecentSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your latest tracks"
                android:textSize="11sp"
                android:textColor="@color/textSecondary"
                android:layout_marginTop="1dp"
                android:alpha="0.75"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecent"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvMostPlayedTitle"
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Most played"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/tvMostPlayedSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Based on your listening activity"
                android:textSize="11sp"
                android:textColor="@color/textSecondary"
                android:layout_marginTop="1dp"
                android:alpha="0.75"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMostPlayed"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvAllSongsTitle"
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All songs"
                android:layout_marginTop="16dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSongs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Albums"
                style="@style/SectionTitle"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Browse by album"
                android:textSize="13sp"
                android:textColor="@color/textSecondary"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAlbums"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="40dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>