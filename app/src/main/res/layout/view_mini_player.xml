<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/miniPlayer"
    android:layout_width="match_parent"
    android:layout_height="76dp"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="24dp"
    android:background="@drawable/bg_miniplayer_glass"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="4dp"
    android:visibility="gone">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivMiniCover"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:scaleType="centerCrop"
        android:translationY="-4dp"
        app:shapeAppearanceOverlay="@style/RoundedContinueCover"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:id="@+id/tvMiniTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:textColor="@color/textPrimary"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toEndOf="@id/ivMiniCover"
        app:layout_constraintTop_toTopOf="@id/ivMiniCover"
        app:layout_constraintEnd_toStartOf="@id/btnMiniPrev"/>

    <TextView
        android:id="@+id/tvMiniArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:textColor="@color/textSecondary"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toEndOf="@id/ivMiniCover"
        app:layout_constraintTop_toBottomOf="@id/tvMiniTitle"
        app:layout_constraintBottom_toBottomOf="@id/ivMiniCover"
        app:layout_constraintEnd_toStartOf="@id/btnMiniPrev"/>

    <ImageButton
        android:id="@+id/btnMiniPrev"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_prev"
        app:tint="@color/textPrimary"
        android:translationY="-3dp"
        app:layout_constraintEnd_toStartOf="@id/btnMiniPlay"
        app:layout_constraintTop_toTopOf="@id/ivMiniCover"
        app:layout_constraintBottom_toBottomOf="@id/ivMiniCover"/>

    <ImageButton
        android:id="@+id/btnMiniPlay"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_play"
        app:tint="@color/textPrimary"
        android:translationY="-3dp"
        app:layout_constraintEnd_toStartOf="@id/btnMiniNext"
        app:layout_constraintTop_toTopOf="@id/ivMiniCover"
        app:layout_constraintBottom_toBottomOf="@id/ivMiniCover"/>

    <ImageButton
        android:id="@+id/btnMiniNext"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_next"
        app:tint="@color/textPrimary"
        android:translationY="-3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/ivMiniCover"
        app:layout_constraintBottom_toBottomOf="@id/ivMiniCover"/>

    <ProgressBar
        android:id="@+id/miniProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:max="1000"
        android:indeterminate="false"
        android:progressDrawable="@drawable/mini_player_progress"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>