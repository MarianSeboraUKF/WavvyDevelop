<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="26dp"
        android:background="@drawable/background_dialog_modern">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Edit song"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@color/textPrimary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/labelCover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cover"
            android:textStyle="bold|italic"
            android:textColor="#88FFFFFF"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"/>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivCoverEdit"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedImage"
            app:layout_constraintTop_toBottomOf="@id/labelCover"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/labelTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Title"
            android:textStyle="bold|italic"
            android:textColor="#88FFFFFF"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/ivCoverEdit"
            app:layout_constraintStart_toStartOf="parent"/>

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:hint="Title"
            android:background="@drawable/background_input_modern"
            android:textColor="@color/textPrimary"
            android:textColorHint="#66FFFFFF"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/labelTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/labelArtist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Artist"
            android:textStyle="bold|italic"
            android:textColor="#88FFFFFF"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/etTitle"
            app:layout_constraintStart_toStartOf="parent"/>

        <EditText
            android:id="@+id/etArtist"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:hint="Main artist"
            android:background="@drawable/background_input_modern"
            android:textColor="@color/textPrimary"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/labelArtist"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/labelFeatArtist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Feat artist"
            android:textStyle="bold|italic"
            android:textColor="#88FFFFFF"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/etArtist"
            app:layout_constraintStart_toStartOf="parent"/>

        <EditText
            android:id="@+id/etFeatArtist"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:hint="Feat artist"
            android:background="@drawable/background_input_modern"
            android:textColor="@color/textPrimary"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/labelFeatArtist"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/labelAlbumArtist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Album artist"
            android:textStyle="bold|italic"
            android:textColor="#88FFFFFF"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/etFeatArtist"
            app:layout_constraintStart_toStartOf="parent"/>

        <EditText
            android:id="@+id/etAlbumArtist"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:hint="Album artist"
            android:background="@drawable/background_input_modern"
            android:textColor="@color/textPrimary"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/labelAlbumArtist"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/labelAlbum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Album"
            android:textStyle="bold|italic"
            android:textColor="#88FFFFFF"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/etAlbumArtist"
            app:layout_constraintStart_toStartOf="parent"/>

        <EditText
            android:id="@+id/etAlbum"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:hint="Album"
            android:background="@drawable/background_input_modern"
            android:textColor="@color/textPrimary"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/labelAlbum"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/labelTrack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track number"
            android:textStyle="bold|italic"
            android:textColor="#88FFFFFF"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/etAlbum"
            app:layout_constraintStart_toStartOf="parent"/>

        <EditText
            android:id="@+id/etTrack"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:hint="Track number"
            android:inputType="number"
            android:background="@drawable/background_input_modern"
            android:textColor="@color/textPrimary"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/labelTrack"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/labelProducer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Producer"
            android:textStyle="bold|italic"
            android:textColor="#88FFFFFF"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/etTrack"
            app:layout_constraintStart_toStartOf="parent"/>

        <EditText
            android:id="@+id/etProducer"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:hint="Producer"
            android:background="@drawable/background_input_modern"
            android:textColor="@color/textPrimary"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/labelProducer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="160dp"
            android:layout_height="50dp"
            android:layout_marginTop="22dp"
            android:text="Save"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:backgroundTint="@color/accent"
            app:layout_constraintTop_toBottomOf="@id/etProducer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#AAAAAA"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnSave"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>