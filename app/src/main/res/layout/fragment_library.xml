<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvAppTitle"
            style="@style/WavvyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wavvy"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/tvLibraryTitle"
            style="@style/SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Library"
            android:layout_marginTop="6dp"/>

        <Button
            android:id="@+id/btnCreatePlaylist"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:layout_marginTop="12dp"
            android:text="Create playlist"
            android:textStyle="bold"
            android:backgroundTint="@color/accent"
            android:textColor="@color/textPrimary"
            android:layout_gravity="center_horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"/>

        <TextView
            android:id="@+id/tvLibrarySubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your saved collection"
            android:textStyle="italic"
            android:textSize="14sp"
            android:textColor="@color/textSecondary"
            android:alpha="0.75"
            android:layout_marginTop="6dp"
            android:layout_gravity="center_horizontal"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/libraryScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="180dp">

            <TextView
                android:id="@+id/tvPlaylistsSection"
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Playlists"
                android:layout_marginTop="4dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPlaylists"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvAlbumsSection"
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Albums"
                android:layout_marginTop="20dp"/>

            <TextView
                android:id="@+id/tvSinglesSection"
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Singles"
                android:layout_marginTop="20dp"/>

            <TextView
                android:id="@+id/tvArtistsSection"
                style="@style/SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Artists"
                android:layout_marginTop="20dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="220dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>