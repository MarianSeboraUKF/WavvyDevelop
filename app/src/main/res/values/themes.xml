<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Wavvy" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="Theme.Wavvy.Player" parent="Theme.Wavvy">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.Wavvy.Splash" parent="Theme.SplashScreen" tools:targetApi="31">
        <item name="windowSplashScreenBackground">@color/bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/wavvy_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.Wavvy</item>
    </style>

    <style name="BottomNavTextBig">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>